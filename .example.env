DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

PORT=8000

SSL_STORE_ID=
SSL_STORE_PASSWORD=
SSL_INIT_URL=
SSL_VALIDATION_URL=
SSL_SUCCESS_URL=
SSL_FAIL_URL=
SSL_CANCEL_URL=

# Gmail SMTP
# If you use Gmail, enable 2FA and create an App Password.
# Do NOT use your normal Gmail password here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=SquadLog
# Optional: override "from" string (e.g. "SquadLog <noreply@domain.com>")
# SMTP_FROM=

# AI Daily Report (optional - get free API key at https://console.groq.com)
GROQ_API_KEY=

# Image search: path to Google Cloud service account JSON (optional)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Twilio Voice / IVR
TWILIO_ACCOUNT_SID=twilosid_here
TWILIO_AUTH_TOKEN=twiliotoken_here
TWILIO_PHONE_NUMBER=twilionumber_here
# Used for Twilio Webhooks (e.g. https://xyz.ngrok.io or https://api.yourdomain.com)
SERVER_BASE_URL=http://localhost:3001
