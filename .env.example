# App
NODE_ENV=development
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/innowavecart

# Auth
JWT_SECRET=change-me-in-prod

# Domain / URLs
MAIN_DOMAIN=
FRONTEND_URL=https://innowavecart-console.up.railway.app
API_BASE_URL=http://localhost:8000

# AI (Groq) – dashboard report, messages, sales direction, description suggestion, translation
AIDAILYREPORT=
AINESSAGE=
AISALE=
GROQ_API_KEY=

# Email (SMTP)
SMTP_USER=
SMTP_FROM=
ADMIN_EMAIL=

# SMS (notifications)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=ECOMM

# Payments (SSLCommerz)
SSL_INIT_URL=
SSL_VALIDATION_URL=
SSL_STORE_ID=
SSL_STORE_PASSWORD=
SSL_SUCCESS_URL=
SSL_FAIL_URL=
SSL_CANCEL_URL=

# Optional
LOW_STOCK_THRESHOLD=5
WILDCARD_AUTO_SETUP=false
GOOGLE_APPLICATION_CREDENTIALS=
